generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Category {
  FRONTEND
  BACKEND
  DATABASES
  ADVANCED_BACKEND
  INFRASTRUCTURE
  CLOUD_DEVOPS
}

enum Role {
  STUDENT
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum TrackType {
  FULL_STACK
  MERN_STACK
  ADVANCED
  INTERNEE
}

enum TicketStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

// ─── Auth.js Models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed — null for OAuth users
  role          Role      @default(STUDENT)
  track         TrackType?              // null = unassigned, treated as FULL_STACK

  accounts     Account[]
  sessions     Session[]
  attendances  Attendance[]
  quizAttempts QuizAttempt[]
  assignedTickets Ticket[] @relation("AssignedTickets")
  createdTickets  Ticket[] @relation("CreatedTickets")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Learning Models ───────────────────────────────────────────────────────

model Topic {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  category    Category
  icon        String
  order       Int
  difficulty  Difficulty

  questions     Question[]
  classSessions ClassSession[]
  quizAttempts  QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([slug])
}

model Question {
  id            String @id @default(cuid())
  topicId       String
  topic         Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questionText  String
  options       Json
  correctAnswer Int
  explanation   String
  order         Int    @default(0)

  createdAt DateTime @default(now())

  @@index([topicId])
}

// ─── Schedule & Attendance ─────────────────────────────────────────────────

model ClassSession {
  id          String   @id @default(cuid())
  topicSlug   String
  topic       Topic    @relation(fields: [topicSlug], references: [slug])
  scheduledAt DateTime // The date of this class (start of day UTC)
  month       Int      // 1 = July, 2 = August, 3 = September
  weekNumber  Int      // Week within month (1-5)
  dayNumber   Int      // Overall day number in the cohort (1, 2, 3 ...)
  title       String   // e.g. "Episode 2 – HTML Basics"

  attendances Attendance[]

  createdAt DateTime @default(now())

  @@unique([topicSlug, scheduledAt])
  @@index([scheduledAt])
  @@index([topicSlug])
}

model Attendance {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessionId String
  classSession   ClassSession     @relation(fields: [classSessionId], references: [id])
  status         AttendanceStatus @default(ABSENT)
  quizScore      Int?             // percentage 0-100
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, classSessionId])
  @@index([userId])
  @@index([classSessionId])
}

model QuizAttempt {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicSlug String
  topic     Topic  @relation(fields: [topicSlug], references: [slug])
  score     Int    // correct answers count
  total     Int    // total questions
  answers   Json   // [{questionId, selectedAnswer, correct}]

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([topicSlug])
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  status      TicketStatus   @default(BACKLOG)
  priority    TicketPriority @default(MEDIUM)
  dueDate     DateTime?

  assigneeId  String?
  assignee    User?  @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("CreatedTickets", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([status])
}
